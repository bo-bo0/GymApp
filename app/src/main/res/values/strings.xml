<resources>
    <string name="app_name">GymApp</string>
    <string-array name="giorni_settimana">
        <item>Lunedì</item>
        <item>Martedì</item>
        <item>Mercoledì</item>
        <item>Giovedì</item>
        <item>Venerdì</item>
        <item>Sabato</item>
        <item>Domenica</item>
    </string-array>

    <string-array name="main_menu_options">
        <item>Aggiungi allenamento</item>
        <item>Visualizza scheda</item>
        <item>Opzione 3</item>
    </string-array>
    <style name="RigaEsercizio">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_marginBottom">6dp</item>
    </style>

    <style name="TestoEsercizio">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="BoxKg" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
        <item name="android:layout_width">65dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:hint">Kg</item>
    </style>

    <style name="InputKg">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:inputType">numberDecimal</item>
        <item name="android:textSize">12sp</item>
        <item name="android:padding">6dp</item>
    </style>
</resources>